# 环境变量配置模板
# 复制此文件内容到Vercel的环境变量配置中

# =====================================================
# 应用配置
# =====================================================
NODE_ENV=production

# =====================================================
# 后端API配置
# =====================================================
EXPO_PUBLIC_BACKEND_BASE_URL=https://aetherlink-prod.vercel.app

# =====================================================
# 数据库配置（从Supabase获取）
# =====================================================
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# =====================================================
# Supabase配置（从Supabase Dashboard获取）
# =====================================================
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =====================================================
# 认证配置（使用openssl生成）
# =====================================================
# 生成方法: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_at_least_32_characters
SESSION_SECRET=your_session_secret_here_at_least_32_characters

# =====================================================
# 对象存储配置
# =====================================================
STORAGE_TYPE=supabase
SUPABASE_STORAGE_BUCKET=aetherlink-uploads

# =====================================================
# LLM配置（可选）
# =====================================================
LLM_API_KEY=your_llm_api_key_if_using_ai
LLM_API_BASE_URL=https://api.llm-service.com

# =====================================================
# 其他配置
# =====================================================
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# =====================================================
# 配置说明
# =====================================================
# 1. DATABASE_URL: 在Supabase项目设置中获取
# 2. SUPABASE_URL: https://[project-id].supabase.co
# 3. SUPABASE_ANON_KEY: 在Supabase Settings -> API 中获取
# 4. SUPABASE_SERVICE_ROLE_KEY: 同上（仅后端使用，保密）
# 5. JWT_SECRET: 在终端执行 openssl rand -base64 32 生成
# 6. SESSION_SECRET: 再次执行 openssl rand -base64 32 生成
# 7. LLM_API_KEY: 如果使用AI功能，填入对应服务的API密钥
